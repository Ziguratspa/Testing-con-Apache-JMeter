        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="Buscar_Pacientes_Apellido" enabled="true">
          <stringProp name="WebDriverSampler.script">// Configuración inicial
WDS.sampleResult.sampleStart();
WDS.log.info(&quot;Iniciando búsqueda de pacientes por apellido&quot;);

try {
    // Navegar a la página del formulario
    WDS.browser.get(&quot;http://localhost:8080/formulario.html&quot;);
    WDS.log.info(&quot;Página cargada correctamente&quot;);
    
    // Esperar a que cargue la página
    WDS.browser.manage().timeouts().implicitlyWait(10, java.util.concurrent.TimeUnit.SECONDS);
    
    // Lista de apellidos básicos para prueba
    var apellidos = [&quot;Gómez&quot;, &quot;Rodríguez&quot;, &quot;Martínez&quot;, &quot;Soto&quot;, &quot;Fernández&quot;];

    // Seleccionar apellido aleatorio
    var indiceAleatorio = Math.floor(Math.random() * apellidos.length);
    var apellidoAleatorio = apellidos[indiceAleatorio];
    WDS.log.info(&quot;Buscando pacientes con apellido: &quot; + apellidoAleatorio);
    
    // Localizar campo de búsqueda
    var searchInput = WDS.browser.findElement(org.openqa.selenium.By.id(&quot;searchInput&quot;));
    searchInput.clear();
    searchInput.sendKeys(apellidoAleatorio);
    WDS.log.info(&quot;Apellido ingresado en campo de búsqueda&quot;);
    
    // Hacer clic en botón Buscar
    var btnBuscar = WDS.browser.findElement(org.openqa.selenium.By.id(&quot;btnBuscar&quot;));
    btnBuscar.click();
    WDS.log.info(&quot;Botón Buscar clickeado&quot;);
    
    // Esperar a que carguen resultados
    java.lang.Thread.sleep(2000);
    
    // Verificar resultados
    var resultados = WDS.browser.findElements(org.openqa.selenium.By.cssSelector(&quot;.patient-item&quot;));
    var cantidadResultados = resultados.size();

    WDS.log.info(&quot;Encontrados &quot; + cantidadResultados + &quot; resultados para apellido: &quot; + apellidoAleatorio);

    // Validar resultados
    if (cantidadResultados &gt;= 0) {
        // La búsqueda fue exitosa (0 resultados también cuenta)
        WDS.sampleResult.setSuccessful(true);
        WDS.sampleResult.setResponseMessage(&quot;Búsqueda completada. Resultados: &quot; + cantidadResultados);

        if (cantidadResultados &gt; 0) {
            var primerResultado = resultados.get(0);
            primerResultado.click();
            WDS.log.info(&quot;Cargando datos del primer resultado&quot;);
            java.lang.Thread.sleep(1000);
        }
    } else {
        WDS.sampleResult.setSuccessful(false);
        WDS.sampleResult.setResponseMessage(&quot;Error en la búsqueda&quot;);
    }

} catch (e) {
    WDS.log.error(&quot;Error durante la búsqueda: &quot; + e.toString());
    WDS.sampleResult.setSuccessful(false);
    WDS.sampleResult.setResponseMessage(&quot;Error: &quot; + e.toString());
}

// Finalizar la muestra
WDS.sampleResult.sampleEnd();</stringProp>
