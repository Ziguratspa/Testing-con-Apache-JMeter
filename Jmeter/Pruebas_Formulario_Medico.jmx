            email: &quot;paciente&quot; + id + &quot;@test.com&quot;,
            fechaNacimiento: &quot;1980-01-01&quot;,
            estadoCivil: &quot;soltero&quot;,
            comentarios: &quot;Paciente de prueba &quot; + id,
            fechaRegistro: new Date().toISOString(),
            fechaActualizacion: new Date().toISOString()
        };
