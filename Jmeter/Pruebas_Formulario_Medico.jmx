          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Escritura_Crear_Paciente" enabled="true">
            <stringProp name="scriptLanguage">java</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// ESCRITURAS (30%) - Creación de nuevos pacientes
var sampleResult = SampleResult;
sampleResult.sampleStart();

var log = org.apache.logging.log4j.LogManager.getLogger(&quot;EscriturasTest&quot;);

try {
    // Generar ID único para evitar conflictos en concurrencia
    var timestamp = new Date().getTime();
    var randomId = Math.floor(Math.random() * 1000000);
    var uniqueId = timestamp + &quot;_&quot; + randomId;
    
    // Datos realistas para nuevo paciente
    var nombresLista = [&quot;Juan&quot;, &quot;María&quot;, &quot;Carlos&quot;, &quot;Ana&quot;, &quot;Pedro&quot;, &quot;Laura&quot;, &quot;Diego&quot;, &quot;Elena&quot;, &quot;Roberto&quot;, &quot;Isabel&quot;];
    var apellidosLista = [&quot;Gómez&quot;, &quot;Rodríguez&quot;, &quot;Martínez&quot;, &quot;López&quot;, &quot;García&quot;, &quot;Pérez&quot;, &quot;Sánchez&quot;, &quot;Ramírez&quot;, &quot;Flores&quot;, &quot;Díaz&quot;];
    var ciudadesLista = [&quot;Santiago&quot;, &quot;Valparaíso&quot;, &quot;Concepción&quot;, &quot;La Serena&quot;, &quot;Antofagasta&quot;, &quot;Temuco&quot;, &quot;Rancagua&quot;, &quot;Talca&quot;];
    
    var nombreAleatorio = nombresLista[Math.floor(Math.random() * nombresLista.length)];
    var apellidoAleatorio = apellidosLista[Math.floor(Math.random() * apellidosLista.length)];
    var ciudadAleatoria = ciudadesLista[Math.floor(Math.random() * ciudadesLista.length)];
    
    // Generar RUT chileno válido
    var numeroRut = 15000000 + Math.floor(Math.random() * 5000000);
    var digitoVerificador = calcularDigitoVerificador(numeroRut);
    
    var paciente = {
        rut: numeroRut + &quot;-&quot; + digitoVerificador,
        nombres: nombreAleatorio + &quot; &quot; + nombresLista[Math.floor(Math.random() * nombresLista.length)],
        apellidos: apellidoAleatorio + &quot; &quot; + apellidosLista[Math.floor(Math.random() * apellidosLista.length)],
        direccion: &quot;Av. &quot; + [&quot;Libertad&quot;, &quot;Principal&quot;, &quot;Los Heroes&quot;, &quot;Portugal&quot;, &quot;España&quot;][Math.floor(Math.random() * 5)] + &quot; &quot; + (Math.floor(Math.random() * 2000) + 1),
        ciudad: ciudadAleatoria,
        telefono: &quot;+569&quot; + (80000000 + Math.floor(Math.random() * 20000000)),
        email: &quot;paciente.&quot; + uniqueId + &quot;@clinica.com&quot;,
        fechaNacimiento: generarFechaNacimiento(),
        estadoCivil: [&quot;soltero&quot;, &quot;casado&quot;, &quot;divorciado&quot;, &quot;viudo&quot;, &quot;unión civil&quot;][Math.floor(Math.random() * 5)],
        comentarios: &quot;Paciente registrado en prueba de carga - &quot; + new Date().toLocaleString(),
        fechaRegistro: new Date().toISOString(),
        fechaActualizacion: new Date().toISOString()
    };
    
    log.info(&quot;➕ Creando nuevo paciente: &quot; + paciente.rut);
    
    // Simular tiempo de escritura en base de datos (100-300ms)
    var tiempoEscritura = 100 + (Math.random() * 200);
    java.lang.Thread.sleep(tiempoEscritura);
    
    var responseMessage = &quot;✅ PACIENTE CREADO: &quot; + paciente.nombres + &quot; &quot; + paciente.apellidos + 
                         &quot; | RUT: &quot; + paciente.rut + 
                         &quot; | Tel: &quot; + paciente.telefono + 
                         &quot; | Ciudad: &quot; + paciente.ciudad +
                         &quot; | Tiempo: &quot; + tiempoEscritura.toFixed(0) + &quot;ms&quot;;
    
    sampleResult.setResponseData(responseMessage, &quot;UTF-8&quot;);
    sampleResult.setSuccessful(true);
    
    log.info(&quot;Escritura exitosa: &quot; + paciente.rut + &quot; | Tiempo: &quot; + tiempoEscritura.toFixed(0) + &quot;ms&quot;);
    
} catch (e) {
    var errorMessage = &quot;❌ ERROR creando paciente: &quot; + e.toString();
    sampleResult.setResponseData(errorMessage, &quot;UTF-8&quot;);
    sampleResult.setSuccessful(false);
    log.error(&quot;Error en operación de escritura: &quot; + e.toString());
}

sampleResult.sampleEnd();

// Función auxiliar para calcular dígito verificador RUT
function calcularDigitoVerificador(rut) {
    var cuerpo = rut.toString();
    var suma = 0;
    var multiplo = 2;
    
    for (var i = 1; i &lt;= cuerpo.length; i++) {
        var index = multiplo * parseInt(cuerpo.charAt(cuerpo.length - i));
        suma += index;
        if (multiplo &lt; 7) multiplo += 1;
        else multiplo = 2;
    }
    
    var dvEsperado = 11 - (suma % 11);
    if (dvEsperado === 10) return &apos;K&apos;;
    if (dvEsperado === 11) return &apos;0&apos;;
    return dvEsperado.toString();
}

// Función para generar fecha de nacimiento aleatoria
function generarFechaNacimiento() {
    var start = new Date(1950, 0, 1);
    var end = new Date(2000, 0, 1);
    var fecha = new Date(start.getTime() + Math.random() * (end.getTime() - start.getTime()));
    return fecha.toISOString().split(&apos;T&apos;)[0];
}</stringProp>
          </JSR223Sampler>
