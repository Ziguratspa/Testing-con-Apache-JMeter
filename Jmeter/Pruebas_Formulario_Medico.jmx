        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="Llenar_Formulario_Automatico" enabled="true">
          <stringProp name="WebDriverSampler.script">// Configuración inicial
WDS.sampleResult.sampleStart();
WDS.log.info(&quot;Iniciando llenado de formulario médico&quot;);

try {
    // Navegar a la página del formulario
    WDS.browser.get(&quot;http://localhost:8080/formulario.html&quot;);
    WDS.log.info(&quot;Página cargada correctamente&quot;);
    
    // Esperar a que cargue la página
    WDS.browser.manage().timeouts().implicitlyWait(10, java.util.concurrent.TimeUnit.SECONDS);
    
    // Generar datos aleatorios para evitar duplicados
    var randomId = Math.floor(Math.random() * 10000);
    var randomRut = Math.floor(Math.random() * 20000000) + 1000000;
    var digitoVerificador = calcularDigitoVerificador(randomRut);
    
    // 1. Llenar campo RUT
    var rutField = WDS.browser.findElement(org.openqa.selenium.By.id(&quot;rut&quot;));
    rutField.clear();
    rutField.sendKeys(randomRut + &quot;-&quot; + digitoVerificador);
    WDS.log.info(&quot;RUT completado: &quot; + randomRut + &quot;-&quot; + digitoVerificador);
    
    // 2. Llenar campo Nombres
    var nombresField = WDS.browser.findElement(org.openqa.selenium.By.id(&quot;nombres&quot;));
    nombresField.clear();
    nombresField.sendKeys(&quot;Usuario&quot; + randomId);
    WDS.log.info(&quot;Nombres completados&quot;);
    
    // 3. Llenar campo Apellidos
    var apellidosField = WDS.browser.findElement(org.openqa.selenium.By.id(&quot;apellidos&quot;));
    apellidosField.clear();
    apellidosField.sendKeys(&quot;Apellido&quot; + randomId);
    WDS.log.info(&quot;Apellidos completados&quot;);
    
    // 4. Llenar campo Dirección
    var direccionField = WDS.browser.findElement(org.openqa.selenium.By.id(&quot;direccion&quot;));
    direccionField.clear();
    direccionField.sendKeys(&quot;Calle Prueba &quot; + randomId);
    WDS.log.info(&quot;Dirección completada&quot;);
    
    // 5. Llenar campo Ciudad
    var ciudadField = WDS.browser.findElement(org.openqa.selenium.By.id(&quot;ciudad&quot;));
    ciudadField.clear();
    ciudadField.sendKeys(&quot;Ciudad&quot; + randomId);
    WDS.log.info(&quot;Ciudad completada&quot;);
    
    // 6. Llenar campo Teléfono
    var telefonoField = WDS.browser.findElement(org.openqa.selenium.By.id(&quot;telefono&quot;));
    telefonoField.clear();
    telefonoField.sendKeys(&quot;+569&quot; + (1000000 + randomId));
    WDS.log.info(&quot;Teléfono completado&quot;);
    
    // 7. Llenar campo Email
    var emailField = WDS.browser.findElement(org.openqa.selenium.By.id(&quot;email&quot;));
    emailField.clear();
    emailField.sendKeys(&quot;test&quot; + randomId + &quot;@correo.com&quot;);
    WDS.log.info(&quot;Email completado&quot;);
    
    // 8. Llenar campo Fecha de Nacimiento
    var fechaField = WDS.browser.findElement(org.openqa.selenium.By.id(&quot;fechaNacimiento&quot;));
    fechaField.clear();
    fechaField.sendKeys(&quot;1990-01-15&quot;);
    WDS.log.info(&quot;Fecha de nacimiento completada&quot;);
    
    // 9. Seleccionar Estado Civil (aleatorio)
    var estadoCivilField = WDS.browser.findElement(org.openqa.selenium.By.id(&quot;estadoCivil&quot;));
    var opciones = [&quot;soltero&quot;, &quot;casado&quot;, &quot;divorciado&quot;, &quot;viudo&quot;, &quot;union&quot;];
    var opcionAleatoria = opciones[Math.floor(Math.random() * opciones.length)];
    
    var select = new org.openqa.selenium.support.ui.Select(estadoCivilField);
    select.selectByValue(opcionAleatoria);
    WDS.log.info(&quot;Estado civil seleccionado: &quot; + opcionAleatoria);
    
    // 10. Llenar campo Comentarios
    var comentariosField = WDS.browser.findElement(org.openqa.selenium.By.id(&quot;comentarios&quot;));
    comentariosField.clear();
    comentariosField.sendKeys(&quot;Paciente de prueba &quot; + randomId + &quot; - Datos generados automáticamente&quot;);
    WDS.log.info(&quot;Comentarios completados&quot;);
    
    // 11. Hacer clic en el botón Guardar
    var btnGuardar = WDS.browser.findElement(org.openqa.selenium.By.id(&quot;btnGuardar&quot;));
    btnGuardar.click();
    WDS.log.info(&quot;Botón Guardar clickeado&quot;);
    
    // Esperar a que se procese el guardado
    java.lang.Thread.sleep(2000);
    
    // Verificar que no hay errores de validación
    var errores = WDS.browser.findElements(org.openqa.selenium.By.cssSelector(&quot;.error-message.show-error&quot;));
    if (errores.size() &gt; 0) {
        WDS.log.error(&quot;Se encontraron errores de validación: &quot; + errores.size());
        WDS.sampleResult.setSuccessful(false);
        WDS.sampleResult.setResponseMessage(&quot;Errores de validación encontrados&quot;);
    } else {
        WDS.log.info(&quot;Formulario enviado exitosamente sin errores&quot;);
        WDS.sampleResult.setSuccessful(true);
        WDS.sampleResult.setResponseMessage(&quot;Formulario completado y enviado correctamente&quot;);
    }
    
} catch (e) {
    WDS.log.error(&quot;Error durante la ejecución: &quot; + e.toString());
    WDS.sampleResult.setSuccessful(false);
    WDS.sampleResult.setResponseMessage(&quot;Error: &quot; + e.toString());
}

WDS.sampleResult.sampleEnd();

// Función auxiliar para calcular dígito verificador RUT
function calcularDigitoVerificador(rut) {
    var cuerpo = rut.toString();
    var suma = 0;
    var multiplo = 2;
    
    for (var i = 1; i &lt;= cuerpo.length; i++) {
        var index = multiplo * parseInt(cuerpo.charAt(cuerpo.length - i));
        suma += index;
        if (multiplo &lt; 7) multiplo += 1;
        else multiplo = 2;
    }
    
    var dvEsperado = 11 - (suma % 11);
    if (dvEsperado === 10) return &apos;K&apos;;
    if (dvEsperado === 11) return &apos;0&apos;;
    return dvEsperado.toString();
}</stringProp>
