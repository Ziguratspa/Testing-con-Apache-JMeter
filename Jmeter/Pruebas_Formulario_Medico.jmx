    var startTimeSet = java.lang.System.currentTimeMillis();
    
    // Simular localStorage.setItem
    var datosJSON = JSON.stringify(dataset);
    resultados.tamañoDatos = datosJSON.length;
    
    // Simular la operación de guardado
    for (var j = 0; j &lt; 100; j++) {
        // Operación de escritura simulada
        var temp = JSON.parse(datosJSON);
        temp.timestamp = new Date().getTime();
        var resultado</stringProp>
