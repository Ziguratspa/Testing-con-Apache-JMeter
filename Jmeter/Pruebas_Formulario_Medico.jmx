          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Busqueda_LocalStorage_Simulada" enabled="true">
            <stringProp name="scriptLanguage">java</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// Simular búsqueda en localStorage - OPERACIÓN DE LECTURA
var sampleResult = SampleResult;
sampleResult.sampleStart();

// Obtener logger para monitoreo
var log = org.apache.logging.log4j.LogManager.getLogger(&quot;LecturasTest&quot;);

try {
    // Lista de apellidos realistas para búsqueda
    var apellidos = [&quot;Gómez&quot;, &quot;Rodríguez&quot;, &quot;Martínez&quot;, &quot;López&quot;, &quot;García&quot;, &quot;Pérez&quot;, &quot;Sánchez&quot;, &quot;Ramírez&quot;, &quot;Flores&quot;, &quot;Díaz&quot;];
    var apellidoAleatorio = apellidos[Math.floor(Math.random() * apellidos.length)];
    
    log.info(&quot;Iniciando búsqueda por apellido: &quot; + apellidoAleatorio);
    
    // Simular tiempo de búsqueda en localStorage (50-150ms)
    var tiempoBusqueda = 50 + Math.random() * 100;
    java.lang.Thread.sleep(tiempoBusqueda);
    
    // Simular resultados aleatorios (0-9 pacientes encontrados)
    var resultados = Math.floor(Math.random() * 10);
    
    // Mensaje de respuesta realista
    var responseMessage = &quot;&quot;;
    if (resultados === 0) {
        responseMessage = &quot;🔍 Búsqueda: &apos;&quot; + apellidoAleatorio + &quot;&apos; - No se encontraron pacientes&quot;;
    } else if (resultados === 1) {
        responseMessage = &quot;🔍 Búsqueda: &apos;&quot; + apellidoAleatorio + &quot;&apos; - 1 paciente encontrado&quot;;
    } else {
        responseMessage = &quot;🔍 Búsqueda: &apos;&quot; + apellidoAleatorio + &quot;&apos; - &quot; + resultados + &quot; pacientes encontrados&quot;;
    }
    
    // Establecer respuesta exitosa
    sampleResult.setResponseData(responseMessage, &quot;UTF-8&quot;);
    sampleResult.setSuccessful(true);
    
    // Log para monitoreo en tiempo real
    log.info(&quot;Búsqueda completada: &quot; + apellidoAleatorio + &quot; | Resultados: &quot; + resultados + &quot; | Tiempo: &quot; + tiempoBusqueda + &quot;ms&quot;);
    
} catch (e) {
    // Manejo de errores
    var errorMessage = &quot;❌ Error en búsqueda: &quot; + e.toString();
    sampleResult.setResponseData(errorMessage, &quot;UTF-8&quot;);
    sampleResult.setSuccessful(false);
    sampleResult.setResponseMessage(&quot;Fallo en búsqueda localStorage&quot;);
    
    log.error(&quot;Error en operación de lectura: &quot; + e.toString());
}

sampleResult.sampleEnd();</stringProp>
          </JSR223Sampler>
