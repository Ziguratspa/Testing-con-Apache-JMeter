        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="Validacion_RUT_Performance" enabled="true">
          <stringProp name="WebDriverSampler.script">// Configuración inicial
WDS.sampleResult.sampleStart();
WDS.log.info(&quot;Iniciando prueba de rendimiento de validación RUT&quot;);

try {
    // Navegar a la página del formulario
    WDS.browser.get(&quot;http://localhost:8080/formulario.html&quot;);
    WDS.log.info(&quot;Página cargada correctamente&quot;);
    
    // Esperar a que cargue la página
    WDS.browser.manage().timeouts().implicitlyWait(5, java.util.concurrent.TimeUnit.SECONDS);
    
    // Lista de RUTs para prueba (25 válidos + 25 inválidos)
    var rutsValidos = [
        &quot;12345678-9&quot;, &quot;18765432-4&quot;, &quot;20456789-3&quot;, &quot;15678901-2&quot;, &quot;13456789-0&quot;,
        &quot;17654321-5&quot;, &quot;19876543-2&quot;, &quot;14567890-1&quot;, &quot;16789012-3&quot;, &quot;18901234-5&quot;,
        &quot;11223344-6&quot;, &quot;15556677-8&quot;, &quot;16677889-0&quot;, &quot;17788990-1&quot;, &quot;18899001-2&quot;,
        &quot;19900112-3&quot;, &quot;20012345-4&quot;, &quot;21123456-5&quot;, &quot;22234567-6&quot;, &quot;23345678-7&quot;,
        &quot;24456789-8&quot;, &quot;25567890-9&quot;, &quot;26678901-0&quot;, &quot;27789012-1&quot;, &quot;28890123-2&quot;
    ];
    
    var rutsInvalidos = [
        &quot;12345678-0&quot;, &quot;11111111-2&quot;, &quot;99999999-9&quot;, &quot;12345678-X&quot;, &quot;00000000-0&quot;,
        &quot;1234567-89&quot;, &quot;123456789-0&quot;, &quot;ABCDEFGH-K&quot;, &quot;12345678-&quot;, &quot;-9&quot;, &quot;12345678-91&quot;,
        &quot;12345678-92&quot;, &quot;12345678-93&quot;, &quot;12345678-94&quot;, &quot;12345678-95&quot;, &quot;12345678-96&quot;,
        &quot;12345678-97&quot;, &quot;12345678-98&quot;, &quot;12345678-99&quot;, &quot;12345678-90&quot;, &quot;12345678-12&quot;,
        &quot;12345678-34&quot;, &quot;12345678-56&quot;, &quot;12345678-78&quot;, &quot;12345678-11&quot;
    ];
    
    // Combinar y mezclar RUTs
    var todosLosRUTs = rutsValidos.concat(rutsInvalidos);
    
    // Función para mezclar array (Fisher-Yates shuffle)
    function mezclarArray(array) {
        for (var i = array.length - 1; i &gt; 0; i--) {
            var j = Math.floor(Math.random() * (i + 1));
            var temp = array[i];
            array[i] = array[j];
            array[j] = temp;
        }
        return array;
    }
    
    var rutsMezclados = mezclarArray(todosLosRUTs);
    var rutIndex = parseInt(vars.get(&quot;RUT_INDEX&quot;)) || 0;
    var rutActual = rutsMezclados[rutIndex];
    
    WDS.log.info(&quot;Probando RUT #&quot; + (rutIndex + 1) + &quot;: &quot; + rutActual);
    
    // 1. Localizar campo RUT
    var rutField = WDS.browser.findElement(org.openqa.selenium.By.id(&quot;rut&quot;));
    
    // 2. Limpiar campo y ingresar RUT
    rutField.clear();
    var startTime = java.lang.System.currentTimeMillis();
    rutField.sendKeys(rutActual);
    
    // 3. Disparar evento blur para activar validación
    WDS.browser.executeScript(&quot;arguments[0].blur();&quot;, rutField);
    
    // 4. Esperar a que se complete la validación
    java.lang.Thread.sleep(500);
    
    var endTime = java.lang.System.currentTimeMillis();
    var tiempoValidacion = endTime - startTime;
    
    // 5. Verificar resultado de validación
    var tieneError = rutField.getAttribute(&quot;class&quot;).contains(&quot;error&quot;);
    var esValido = rutsValidos.indexOf(rutActual) !== -1;
    
    var validacionCorrecta = (esValido &amp;&amp; !tieneError) || (!esValido &amp;&amp; tieneError);
    
    WDS.log.info(&quot;RUT: &quot; + rutActual + 
                &quot; | Válido: &quot; + esValido + 
                &quot; | Error UI: &quot; + tieneError + 
                &quot; | Tiempo: &quot; + tiempoValidacion + &quot;ms&quot; +
                &quot; | Validación Correcta: &quot; + validacionCorrecta);
    
    // 6. Guardar métricas
    vars.put(&quot;TIEMPO_VALIDACION_&quot; + rutIndex, tiempoValidacion.toString());
    vars.put(&quot;RUT_VALIDO_&quot; + rutIndex, esValido.toString());
    vars.put(&quot;VALIDACION_CORRECTA_&quot; + rutIndex, validacionCorrecta.toString());
    
    // 7. Preparar para siguiente iteración
    rutIndex++;
    vars.put(&quot;RUT_INDEX&quot;, rutIndex.toString());
    
    if (rutIndex &gt;= rutsMezclados.length) {
        WDS.log.info(&quot;Completadas todas las validaciones RUT&quot;);
        vars.put(&quot;RUT_INDEX&quot;, &quot;0&quot;); // Reset para posibles repeticiones
    }
    
    // 8. Establecer resultado
    if (validacionCorrecta) {
        WDS.sampleResult.setSuccessful(true);
        WDS.sampleResult.setResponseMessage(&quot;Validación RUT exitosa. Tiempo: &quot; + tiempoValidacion + &quot;ms&quot;);
    } else {
        WDS.sampleResult.setSuccessful(false);
        WDS.sampleResult.setResponseMessage(&quot;Error en validación RUT. Tiempo: &quot; + tiempoValidacion + &quot;ms&quot;);
    }
    
} catch (e) {
    WDS.log.error(&quot;Error durante validación RUT: &quot; + e.toString());
    WDS.sampleResult.setSuccessful(false);
    WDS.sampleResult.setResponseMessage(&quot;Error: &quot; + e.toString());
}

WDS.sampleResult.sampleEnd();</stringProp>
          <stringProp name="WebDriverSampler.parameters"></stringProp>
