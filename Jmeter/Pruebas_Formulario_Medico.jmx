          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Actualizacion_Modificar_Paciente" enabled="true">
            <stringProp name="scriptLanguage">java</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// ACTUALIZACIONES (20%) - Modificación de pacientes existentes
var sampleResult = SampleResult;
sampleResult.sampleStart();

var log = org.apache.logging.log4j.LogManager.getLogger(&quot;ActualizacionesTest&quot;);

try {
    // RUTs de pacientes existentes que podrían actualizarse
    var rutsExistentes = [
        &quot;12345678-9&quot;, &quot;98765432-1&quot;, &quot;11222333-4&quot;, &quot;44555666-7&quot;, 
        &quot;77888999-K&quot;, &quot;10111222-3&quot;, &quot;13141516-9&quot;, &quot;17181920-1&quot;,
        &quot;21222324-5&quot;, &quot;25262728-0&quot;
    ];
    var rutAleatorio = rutsExistentes[Math.floor(Math.random() * rutsExistentes.length)];
    
    // Campos que podrían actualizarse
    var camposActualizacion = [
        { 
            campo: &quot;teléfono&quot;, 
            valores: [&quot;+56987654321&quot;, &quot;+56912345678&quot;, &quot;+56955556666&quot;, &quot;+56999998888&quot;, &quot;+56911112222&quot;],
            mensaje: &quot;📞 Teléfono actualizado&quot;
        },
        { 
            campo: &quot;dirección&quot;, 
            valores: [&quot;Av. Libertador 1234&quot;, &quot;C Los Alerces 567&quot;, &quot;Pasaje Los Olmos 890&quot;, &quot;Plaza Central 321&quot;],
            mensaje: &quot;🏠 Dirección actualizada&quot;
        },
        { 
            campo: &quot;email&quot;, 
            valores: [&quot;nuevo.email@clinica.com&quot;, &quot;contacto.actualizado@hospital.com&quot;, &quot;paciente.modificado@correo.com&quot;],
            mensaje: &quot;📧 Email actualizado&quot;
        },
        { 
            campo: &quot;estado civil&quot;, 
            valores: [&quot;casado&quot;, &quot;divorciado&quot;, &quot;viudo&quot;, &quot;unión civil&quot;],
            mensaje: &quot;💍 Estado civil actualizado&quot;
        },
        { 
            campo: &quot;comentarios médicos&quot;, 
            valores: [&quot;Control periódico estable&quot;, &quot;Medicación ajustada&quot;, &quot;Nuevos exámenes solicitados&quot;, &quot;Próximo control en 3 meses&quot;],
            mensaje: &quot;📝 Comentarios médicos actualizados&quot;
        }
    ];
    
    var campoAleatorio = camposActualizacion[Math.floor(Math.random() * camposActualizacion.length)];
    var nuevoValor = campoAleatorio.valores[Math.floor(Math.random() * campoAleatorio.valores.length)];
    
    log.info(&quot;🔄 Actualizando paciente &quot; + rutAleatorio + &quot; - Campo: &quot; + campoAleatorio.campo);
    
    // Simular tiempo de actualización en base de datos (80-230ms)
    var tiempoActualizacion = 80 + (Math.random() * 150);
    java.lang.Thread.sleep(tiempoActualizacion);
    
    var responseMessage = campoAleatorio.mensaje + &quot; | Paciente: &quot; + rutAleatorio + 
                         &quot; | Nuevo valor: &quot; + nuevoValor + 
                         &quot; | Tiempo: &quot; + tiempoActualizacion.toFixed(0) + &quot;ms&quot;;
    
    sampleResult.setResponseData(responseMessage, &quot;UTF-8&quot;);
    sampleResult.setSuccessful(true);
    
    log.info(&quot;Actualización exitosa: &quot; + rutAleatorio + &quot; | Campo: &quot; + campoAleatorio.campo + &quot; | Tiempo: &quot; + tiempoActualizacion.toFixed(0) + &quot;ms&quot;);
    
} catch (e) {
    var errorMessage = &quot;❌ ERROR actualizando paciente: &quot; + e.toString();
    sampleResult.setResponseData(errorMessage, &quot;UTF-8&quot;);
    sampleResult.setSuccessful(false);
    log.error(&quot;Error en operación de actualización: &quot; + e.toString());
}

sampleResult.sampleEnd();</stringProp>
          </JSR223Sampler>
