        <hashTree>
          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Validacion_Estres_Flexible" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">// JSR223 Assertion para validación bajo estrés
// Configuración de umbrales flexibles según fase de estrés

var sampleResult = SampleResult;
var prev = prev; // Referencia al resultado anterior

try {
    // Obtener métricas actuales
    var responseTime = sampleResult.getTime();
    var sampleCount = prev.getSampleCount();
    var errorCount = prev.getErrorCount();
    
    // Calcular tasa de error actual (evitar división por cero)
    var currentErrorRate = 0;
    if (sampleCount + errorCount &gt; 0) {
        currentErrorRate = (errorCount / (sampleCount + errorCount)) * 100;
    }
    
    // Umbrales flexibles según fase de estrés
    var maxTimeStressed = 10000; // 10 segundos máximo bajo estrés extremo
    var maxErrorRateStressed = 10; // 10% máximo bajo estrés
    
    // Obtener fase actual basada en el tiempo de ejecución
    var startTime = sampleResult.getStartTime();
    var currentTime = new Date().getTime();
    var elapsedSeconds = (currentTime - startTime) / 1000;
    
    // Ajustar umbrales según la fase de estrés
    var phaseThresholds = {
        time: maxTimeStressed,
        error: maxErrorRateStressed
    };
    
    // Determinar fase actual y ajustar umbrales
    if (elapsedSeconds &lt; 30) {
        // Fase 1: 50 usuarios - Comportamiento normal
        phaseThresholds.time = 3000; // 3 segundos
        phaseThresholds.error = 2;   // 2%
    } else if (elapsedSeconds &lt; 60) {
        // Fase 2: 100 usuarios - Degradación leve aceptable
        phaseThresholds.time = 5000; // 5 segundos
        phaseThresholds.error = 5;   // 5%
    } else if (elapsedSeconds &lt; 90) {
        // Fase 3: 200 usuarios - Degradación significativa
        phaseThresholds.time = 8000; // 8 segundos
        phaseThresholds.error = 8;   // 8%
    } else {
        // Fase 4: 500 usuarios - Estrés extremo
        phaseThresholds.time = 10000; // 10 segundos
        phaseThresholds.error = 10;   // 10%
    }
    
    // Validar métricas
    var timeValid = responseTime &lt;= phaseThresholds.time;
    var errorValid = currentErrorRate &lt;= phaseThresholds.error;
    
    // Determinar si la assertion falla
    var shouldFail = !(timeValid &amp;&amp; errorValid);
    
    // Configurar mensaje detallado
    var statusMessage = &quot;Fase: &quot; + getPhaseName(elapsedSeconds) + 
                       &quot; | Tiempo: &quot; + responseTime + &quot;ms/&quot; + phaseThresholds.time + &quot;ms&quot; +
                       &quot; | Error: &quot; + currentErrorRate.toFixed(2) + &quot;%/&quot; + phaseThresholds.error + &quot;%&quot; +
                       &quot; | Estado: &quot; + (shouldFail ? &quot;❌ FALLA&quot; : &quot;✅ ACEPTABLE&quot;);
    
    // Configurar el resultado de la assertion
    AssertionResult.setFailure(shouldFail);
    AssertionResult.setFailureMessage(statusMessage);
    
    // Log para monitoreo (solo en caso de falla o para debugging)
    if (shouldFail) {
        log.warn(&quot;Assertion estrés - &quot; + statusMessage);
    }
    
} catch (e) {
    // En caso de error en la assertion, fallar con mensaje descriptivo
    log.error(&quot;Error en JSR223 Assertion: &quot; + e.toString());
    AssertionResult.setFailure(true);
    AssertionResult.setFailureMessage(&quot;Error en validación: &quot; + e.toString());
}

// Función auxiliar para obtener nombre de fase
function getPhaseName(elapsedSeconds) {
    if (elapsedSeconds &lt; 30) return &quot;FASE 1 (50 usuarios)&quot;;
    if (elapsedSeconds &lt; 60) return &quot;FASE 2 (100 usuarios)&quot;;
    if (elapsedSeconds &lt; 90) return &quot;FASE 3 (200 usuarios)&quot;;
    return &quot;FASE 4 (500 usuarios)&quot;;
}</stringProp>
            <stringProp name="scriptLanguage">java</stringProp>
          </JSR223Assertion>
          <hashTree/>
        </hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler" enabled="true">
          <stringProp name="scriptLanguage">java</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">// Simular operaciones mixtas bajo estrés
var randomOperation = Math.floor(Math.random() * 3);
var log = org.apache.logging.log4j.LogManager.getLogger(&quot;EstresTest&quot;);

switch(randomOperation) {
    case 0:
        // Operación de lectura
        log.info(&quot;Simulando lectura bajo estrés&quot;);
        java.lang.Thread.sleep(50 + Math.random() * 100);
        break;
    case 1:
        // Operación de escritura
        log.info(&quot;Simulando escritura bajo estrés&quot;);
        java.lang.Thread.sleep(100 + Math.random() * 200);
        break;
    case 2:
        // Operación de búsqueda
        log.info(&quot;Simulando búsqueda bajo estrés&quot;);
        java.lang.Thread.sleep(150 + Math.random() * 150);
        break;
}

SampleResult.setResponseData(&quot;Operación completada bajo estrés: &quot; + randomOperation);
SampleResult.setSuccessful(true);</stringProp>
        </JSR223Sampler>
        <hashTree>
          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Validacion_Estres_Flexible" enabled="true">
            <stringProp name="scriptLanguage">java</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// JSR223 Assertion para validación bajo estrés
// Configuración de umbrales flexibles según fase de estrés

var sampleResult = SampleResult;
var prev = prev; // Referencia al resultado anterior

try {
    // Obtener métricas actuales
    var responseTime = sampleResult.getTime();
    var sampleCount = prev.getSampleCount();
    var errorCount = prev.getErrorCount();
    
    // Calcular tasa de error actual (evitar división por cero)
    var currentErrorRate = 0;
    if (sampleCount + errorCount &gt; 0) {
        currentErrorRate = (errorCount / (sampleCount + errorCount)) * 100;
    }
    
    // Umbrales flexibles según fase de estrés
    var maxTimeStressed = 10000; // 10 segundos máximo bajo estrés extremo
    var maxErrorRateStressed = 10; // 10% máximo bajo estrés
    
    // Obtener fase actual basada en el tiempo de ejecución
    var startTime = sampleResult.getStartTime();
    var currentTime = new Date().getTime();
    var elapsedSeconds = (currentTime - startTime) / 1000;
    
    // Ajustar umbrales según la fase de estrés
    var phaseThresholds = {
        time: maxTimeStressed,
        error: maxErrorRateStressed
    };
    
    // Determinar fase actual y ajustar umbrales
    if (elapsedSeconds &lt; 30) {
        // Fase 1: 50 usuarios - Comportamiento normal
        phaseThresholds.time = 3000; // 3 segundos
        phaseThresholds.error = 2;   // 2%
    } else if (elapsedSeconds &lt; 60) {
        // Fase 2: 100 usuarios - Degradación leve aceptable
        phaseThresholds.time = 5000; // 5 segundos
        phaseThresholds.error = 5;   // 5%
    } else if (elapsedSeconds &lt; 90) {
        // Fase 3: 200 usuarios - Degradación significativa
        phaseThresholds.time = 8000; // 8 segundos
        phaseThresholds.error = 8;   // 8%
    } else {
        // Fase 4: 500 usuarios - Estrés extremo
        phaseThresholds.time = 10000; // 10 segundos
        phaseThresholds.error = 10;   // 10%
    }
    
    // Validar métricas
    var timeValid = responseTime &lt;= phaseThresholds.time;
    var errorValid = currentErrorRate &lt;= phaseThresholds.error;
    
    // Determinar si la assertion falla
    var shouldFail = !(timeValid &amp;&amp; errorValid);
    
    // Configurar mensaje detallado
    var statusMessage = &quot;Fase: &quot; + getPhaseName(elapsedSeconds) + 
                       &quot; | Tiempo: &quot; + responseTime + &quot;ms/&quot; + phaseThresholds.time + &quot;ms&quot; +
                       &quot; | Error: &quot; + currentErrorRate.toFixed(2) + &quot;%/&quot; + phaseThresholds.error + &quot;%&quot; +
                       &quot; | Estado: &quot; + (shouldFail ? &quot;❌ FALLA&quot; : &quot;✅ ACEPTABLE&quot;);
    
    // Configurar el resultado de la assertion
    AssertionResult.setFailure(shouldFail);
    AssertionResult.setFailureMessage(statusMessage);
    
    // Log para monitoreo (solo en caso de falla o para debugging)
    if (shouldFail) {
        log.warn(&quot;Assertion estrés - &quot; + statusMessage);
    }
    
} catch (e) {
    // En caso de error en la assertion, fallar con mensaje descriptivo
    log.error(&quot;Error en JSR223 Assertion: &quot; + e.toString());
    AssertionResult.setFailure(true);
    AssertionResult.setFailureMessage(&quot;Error en validación: &quot; + e.toString());
}

// Función auxiliar para obtener nombre de fase
function getPhaseName(elapsedSeconds) {
    if (elapsedSeconds &lt; 30) return &quot;FASE 1 (50 usuarios)&quot;;
    if (elapsedSeconds &lt; 60) return &quot;FASE 2 (100 usuarios)&quot;;
    if (elapsedSeconds &lt; 90) return &quot;FASE 3 (200 usuarios)&quot;;
    return &quot;FASE 4 (500 usuarios)&quot;;
}</stringProp>
