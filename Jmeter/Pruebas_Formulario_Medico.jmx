          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Eliminacion_Remover_Paciente" enabled="true">
            <stringProp name="scriptLanguage">java</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// ELIMINACIONES (10%) - Remoción de pacientes del sistema
var sampleResult = SampleResult;
sampleResult.sampleStart();

var log = org.apache.logging.log4j.LogManager.getLogger(&quot;EliminacionesTest&quot;);

try {
    // Simular RUTs de pacientes que podrían eliminarse
    // (En un sistema real, estos serían pacientes creados previamente en pruebas)
    var rutsParaEliminar = [
        &quot;99999991-1&quot;, &quot;99999992-2&quot;, &quot;99999993-3&quot;, &quot;99999994-4&quot;, &quot;99999995-5&quot;,
        &quot;99999996-6&quot;, &quot;99999997-7&quot;, &quot;99999998-8&quot;, &quot;99999999-9&quot;, &quot;99999990-0&quot;
    ];
    var rutEliminar = rutsParaEliminar[Math.floor(Math.random() * rutsParaEliminar.length)];
    
    // Razones de eliminación realistas
    var razonesEliminacion = [
        &quot;Paciente se cambió de ciudad&quot;,
        &quot;Alta médica definitiva&quot;,
        &quot;Paciente solicitó eliminar datos&quot;,
        &quot;Registro duplicado&quot;,
        &quot;Error en registro inicial&quot;,
        &quot;Paciente fallecido&quot;,
        &quot;Transferencia a otra clínica&quot;
    ];
    var razonAleatoria = razonesEliminacion[Math.floor(Math.random() * razonesEliminacion.length)];
    
    log.info(&quot;🗑️ Solicitando eliminación de paciente: &quot; + rutEliminar + &quot; - Razón: &quot; + razonAleatoria);
    
    // Simular tiempo de eliminación en base de datos (60-180ms)
    var tiempoEliminacion = 60 + (Math.random() * 120);
    java.lang.Thread.sleep(tiempoEliminacion);
    
    // Simular confirmación de eliminación
    var responseMessage = &quot;✅ PACIENTE ELIMINADO: RUT &quot; + rutEliminar + 
                         &quot; | Razón: &quot; + razonAleatoria + 
                         &quot; | Tiempo procesamiento: &quot; + tiempoEliminacion.toFixed(0) + &quot;ms&quot; +
                         &quot; | Fecha: &quot; + new Date().toLocaleString();
    
    sampleResult.setResponseData(responseMessage, &quot;UTF-8&quot;);
    sampleResult.setSuccessful(true);
    
    log.info(&quot;Eliminación exitosa: &quot; + rutEliminar + &quot; | Razón: &quot; + razonAleatoria + &quot; | Tiempo: &quot; + tiempoEliminacion.toFixed(0) + &quot;ms&quot;);
    
} catch (e) {
    var errorMessage = &quot;❌ ERROR eliminando paciente: &quot; + e.toString();
    sampleResult.setResponseData(errorMessage, &quot;UTF-8&quot;);
    sampleResult.setSuccessful(false);
    log.error(&quot;Error en operación de eliminación: &quot; + e.toString());
}

sampleResult.sampleEnd();</stringProp>
          </JSR223Sampler>
